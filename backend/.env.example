# Application
APP_NAME=CareerMate AI API
PORT=8000

# Database — path to SQLite file
DATABASE_PATH=./careermate.db

# JWT — change this to a long random string in production
SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Gemini — get your key from https://aistudio.google.com/apikey (free tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:3000
