# Application
APP_NAME=CareerMate AI API
PORT=8000

# Database — MongoDB Atlas (resumes/files stored in GridFS)
MONGODB_URI=
MONGODB_DB=careermate

# JWT — change this to a long random string in production
SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Gemini — get your key from https://aistudio.google.com/apikey (free tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Embedding model for RAG. gemini-embedding-001 is current (3072-dim);
# text-embedding-004 now 404s on the public API.
EMBEDDING_MODEL=gemini-embedding-001
# RAG retrieval depth (chunks fed to the prompt per turn)
RAG_TOP_K_RESUME=4
RAG_TOP_K_JOBS=3

# File uploads
MAX_UPLOAD_SIZE_MB=10

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:3000
