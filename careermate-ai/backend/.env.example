# Application
APP_NAME=CareerMate AI API
DEBUG=false

# Database — SQLite (default) or swap to PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/careermate
DATABASE_URL=sqlite:///./careermate.db

# JWT — change this to a long random string in production
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# Anthropic — get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:3000
